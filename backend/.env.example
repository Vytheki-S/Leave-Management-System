# Database host
DB_HOST=localhost

# Database port
DB_PORT=5432

# Database user
DB_USER=postgres

# Database password
DB_PASSWORD=postgres

# Database name
DB_NAME=leave_management

# SSL mode for PostgreSQL connection
DB_SSLMODE=disable

# JWT secret for token signing (change in production)
JWT_SECRET=your-super-secret-key-change-me

# Server port
PORT=8080
